acme_account.key
device_ca.key
client.key
*.csr
*.crt

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db-journal

# ── Docker ────────────────────────────────────────────────────────────────────
