# ── Environment ───────────────────────────────────────────────────────────────
# One of: dev | staging | production
# Production requires CERTOVUS_ENV=production explicitly — no implicit fallback.
CERTOVUS_ENV=dev

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
BROKER_DB_PATH=./certovus.db

# ── Device CA ─────────────────────────────────────────────────────────────────
# Path to Device CA public certificate (PEM). Private key never goes here.
DEVICE_CA_CERT_PATH=./device_ca.crt

# ── ACME ──────────────────────────────────────────────────────────────────────
# Path to ACME account key (PEM). Generated on first run, chmod 0600.
ACME_ACCOUNT_KEY_PATH=./acme_account.key

# Overridden in dev to point at pebble.
ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Scoped to TXT records in the embetrix.works zone only.
# Leave blank in dev — MockDNS targets challtestsrv instead.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Broker ────────────────────────────────────────────────────────────────────
BROKER_DOMAIN=broker.embetrix.works

# ── DNS propagation ───────────────────────────────────────────────────────────
# Seconds to wait after setting TXT record before notifying ACME.
DNS_PROPAGATION_WAIT=60

# ── Dev / pebble overrides (ignored outside CERTOVUS_ENV=dev) ─────────────────
PEBBLE_URL=https://pebble:14000/dir
CHALLTESTSRV_URL=http://challtestsrv:8055

# ── Admin ─────────────────────────────────────────────────────────────────────
# Default admin name for CLI when --admin flag is omitted.
BROKER_ADMIN_USER=admin

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
