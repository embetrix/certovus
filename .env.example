# ── Environment ───────────────────────────────────────────────────────────────
# One of: dev | staging | production
# Production requires CERTOVUS_ENV=production explicitly — no implicit fallback.
CERTOVUS_ENV=dev

# ── Database ──────────────────────────────────────────────────────────────────
BROKER_DB_PATH=/data/certovus.db

# ── ACME ──────────────────────────────────────────────────────────────────────
# Path to ACME account key (PEM). Generated on first run, chmod 0600.
ACME_ACCOUNT_KEY_PATH=/data/acme_account.key

# ACME directory URL. Overridden in dev docker-compose to point at pebble.
PEBBLE_URL=https://acme-v02.api.letsencrypt.org/directory

# ── Cloudflare (staging / production only) ────────────────────────────────────
# Token scoped to dns_zone:edit for the target zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Set to 0 to disable a limit entirely (useful in dev/test).
RATE_PER_DEVICE=1
RATE_PER_DEVICE_HOURS=24
RATE_GLOBAL=50
RATE_GLOBAL_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
